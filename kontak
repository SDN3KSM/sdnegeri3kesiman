    <form class="form-card" id="contactForm">
      <label for="cnama">Nama Lengkap</label>
      <input type="text" id="cnama" required>
      <label for="cemail">Email</label>
      <input type="email" id="cemail" required>
      <label for="csubjek">Subjek</label>
      <input type="text" id="csubjek" required>
      <label for="cpesan">Pesan</label>
      <textarea id="cpesan" rows="5" required></textarea>
      <button type="submit" class="btn btn-primary" style="width:100%;">Kirim Pesan</button>
      <p id="formMsg" style="display:none;margin-top:16px;background:#EAF3EF;color:#1B6B63;padding:14px 16px;border-radius:10px;font-size:.9rem;"></p>
    </form>
